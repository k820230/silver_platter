#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

requested_enabled="${KRX_KIND_SMOKE_ENABLED:-}"
requested_symbol="${KRX_KIND_SMOKE_SYMBOL:-}"
. scripts/load_local_env

KRX_KIND_SMOKE_ENABLED="${requested_enabled:-${KRX_KIND_SMOKE_ENABLED:-0}}"
KRX_KIND_SMOKE_SYMBOL="${requested_symbol:-${KRX_KIND_SMOKE_SYMBOL:-005930}}"

if [ "${KRX_KIND_SMOKE_ENABLED}" != "1" ]; then
  echo "KRX KIND smoke skipped: set KRX_KIND_SMOKE_ENABLED=1 to run read-only network check"
  exit 0
fi

SYMBOL="${KRX_KIND_SMOKE_SYMBOL}"

PYTHONPATH=src python3 - <<PY
from datetime import date, timedelta

from silver_platter.providers import KrxKindDisclosureProvider

symbol = "${SYMBOL}"
today = date.today()
provider = KrxKindDisclosureProvider(
    begin_date=today - timedelta(days=30),
    end_date=today,
    page_size=10,
)
disclosures = list(provider.get_disclosures(symbol))
print(
    "KRX KIND smoke passed: symbol=%s disclosure_count=%s"
    % (symbol, len(disclosures))
)
PY
