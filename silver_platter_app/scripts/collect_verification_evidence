#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."
. scripts/load_local_env

PYTHONPATH="${PYTHONPATH:+${PYTHONPATH}:}src" python3 - "$@" <<'PY'
import argparse
from datetime import date, datetime, timedelta
import os
from pathlib import Path
import subprocess
import sys
import urllib.request

from silver_platter.accounting import ExecutionPosting, post_execution_fifo
from silver_platter.backtest import BacktestRunConfig, StrategyOrderCandidate, run_backtest
from silver_platter.backup import summarize_backup_restore_status
from silver_platter.broker import BrokerOrderRequest, PaperBrokerAdapter
from silver_platter.data_quality import PriceBarInput, evaluate_price_bars
from silver_platter.replay import (
    ExportedSnapshotReplayConfig,
    run_exported_snapshot_replay,
)
from silver_platter.verification import DEFAULT_GATE_REQUIREMENTS
from silver_platter.verification import (
    GateEvidence,
    backup_status_to_gate_evidence,
    build_verification_evidence_bundle,
    paper_replay_to_gate_evidence,
    script_result_to_gate_evidence,
    write_verification_evidence_bundle,
)


def _run_command(command):
    return subprocess.run(
        command,
        capture_output=True,
        text=True,
    )


def _combined_output(result):
    return "\n".join(part for part in [result.stdout, result.stderr] if part)


def _http_get(url):
    try:
        with urllib.request.urlopen(url, timeout=10) as response:
            body = response.read(200).decode("utf-8", errors="replace")
        return subprocess.CompletedProcess(
            ["GET", url],
            0,
            "status=%s body=%s" % (getattr(response, "status", "ok"), body),
            "",
        )
    except Exception as exc:
        return subprocess.CompletedProcess(
            ["GET", url],
            1,
            "",
            "%s: %s" % (exc.__class__.__name__, exc),
        )


def _collect_local_gate_evidence(checked_at):
    evidence = []

    bar_ts = datetime(2026, 5, 22, 9, 0, 0)
    quality = evaluate_price_bars(
        [
            PriceBarInput(
                "AAPL",
                bar_ts,
                200.0,
                1000.0,
                200000.0,
                bar_ts,
            )
        ]
    )
    evidence.append(
        GateEvidence(
            "price_quality",
            "pass" if quality.status == "ok" else "fail",
            "local:evaluate_price_bars",
            checked_at,
            "status=%s issue_count=%s score=%s"
            % (quality.status, len(quality.issues), quality.score),
        )
    )

    ack = PaperBrokerAdapter().submit_order(
        BrokerOrderRequest(
            order_id="verification-paper-order",
            account_id="verification",
            security_id="AAPL",
            side="buy",
            order_type="limit",
            quantity=1,
            limit_price=200.0,
            market="US",
        )
    )
    evidence.append(
        GateEvidence(
            "simulation_no_broker",
            "pass" if not ack.broker_send_attempted else "fail",
            "local:PaperBrokerAdapter",
            checked_at,
            "broker_send_attempted=%s status=%s" % (ack.broker_send_attempted, ack.status),
        )
    )

    buy = post_execution_fifo(
        ExecutionPosting(
            "verification-buy",
            "verification",
            "AAPL",
            "buy",
            10,
            1000,
            date(2026, 5, 1),
        ),
        [],
    )
    sell = post_execution_fifo(
        ExecutionPosting(
            "verification-sell",
            "verification",
            "AAPL",
            "sell",
            4,
            1200,
            date(2026, 5, 22),
            fee_krw=8,
        ),
        [buy.created_lot],
    )
    evidence.append(
        GateEvidence(
            "fifo_pnl",
            "pass" if sell.realized_pnl_krw == 792 and len(sell.fifo_matches) == 1 else "fail",
            "local:post_execution_fifo",
            checked_at,
            "realized_pnl_krw=%s match_count=%s"
            % (sell.realized_pnl_krw, len(sell.fifo_matches)),
        )
    )

    lookahead_bar = PriceBarInput(
        "AAPL",
        bar_ts,
        20000.0,
        1000.0,
        20000000.0,
        bar_ts + timedelta(minutes=1),
    )

    def strategy(bar):
        return StrategyOrderCandidate(
            security_id=bar.security_id,
            side="buy",
            market="US",
            order_type="limit",
            price=bar.close_price or 0.0,
            quantity=1,
            decision_at=bar.bar_ts,
            avg_daily_turnover_20d_krw=1000000000.0,
        )

    result = run_backtest(
        BacktestRunConfig(
            "verification-lookahead",
            "verification",
            date(2026, 5, 22),
            date(2026, 5, 22),
        ),
        [lookahead_bar],
        strategy,
    )
    accepted_order_count = len([event for event in result.order_events if event.accepted])
    evidence.append(
        GateEvidence(
            "backtest_no_lookahead",
            "pass" if result.lookahead_violation_count > 0 and accepted_order_count == 0 else "fail",
            "local:run_backtest",
            checked_at,
            "lookahead_violation_count=%s accepted_order_count=%s"
            % (result.lookahead_violation_count, accepted_order_count),
        )
    )
    return evidence


def _failed_long_replay_evidence(message, checked_at, evidence_uri):
    detail = "error=%s" % message
    return [
        GateEvidence("paper_replay_duration", "fail", evidence_uri, checked_at, detail),
        GateEvidence("paper_no_broker_send", "fail", evidence_uri, checked_at, detail),
        GateEvidence("paper_no_lookahead", "fail", evidence_uri, checked_at, detail),
    ]


def _collect_long_replay_evidence(snapshot_path, required_min_days, checked_at):
    if not snapshot_path:
        return _failed_long_replay_evidence(
            "LONG_REPLAY_SNAPSHOT_PATH is not configured",
            checked_at,
            "snapshot:missing",
        )
    path = Path(snapshot_path).expanduser()
    if not path.exists():
        return _failed_long_replay_evidence(
            "snapshot is missing: %s" % path,
            checked_at,
            "snapshot:%s" % path,
        )
    try:
        result = run_exported_snapshot_replay(
            ExportedSnapshotReplayConfig(
                run_id="verification-long-replay",
                strategy_id="verification",
                from_date=date(2026, 1, 2),
                to_date=date(2026, 5, 22),
                security_id="005930",
                snapshot_paths=[path],
                required_min_days=required_min_days,
                strategy_plugin_id="fixed-close",
            )
        )
    except Exception as exc:
        return _failed_long_replay_evidence(
            "%s: %s" % (exc.__class__.__name__, exc),
            checked_at,
            "snapshot:%s" % path,
        )
    return paper_replay_to_gate_evidence(
        result.paper_replay_evidence,
        required_min_days,
        checked_at,
    )


def main(argv):
    parser = argparse.ArgumentParser(
        description="Collect local verification outputs into a gate evidence bundle."
    )
    parser.add_argument(
        "--output",
        default=os.getenv(
            "VERIFICATION_EVIDENCE_PATH",
            "var/verification/evidence-bundle.json",
        ),
    )
    parser.add_argument("--skip-check", action="store_true")
    parser.add_argument("--skip-web", action="store_true")
    parser.add_argument("--run-local-gates", action="store_true")
    parser.add_argument("--run-long-replay", action="store_true")
    parser.add_argument("--run-smoke-api", action="store_true")
    parser.add_argument("--no-backup", action="store_true")
    parser.add_argument("--write-goldilocks", action="store_true")
    parser.add_argument("--web-url", default=os.getenv("WEB_URL", "http://localhost:3000"))
    parser.add_argument(
        "--long-replay-snapshot-path",
        default=os.getenv(
            "LONG_REPLAY_SNAPSHOT_PATH",
            os.getenv("REPLAY_SNAPSHOT_PATH", ""),
        ),
    )
    parser.add_argument(
        "--long-replay-required-min-days",
        type=int,
        default=int(os.getenv("LONG_REPLAY_REQUIRED_MIN_DAYS", "30")),
    )
    parser.add_argument(
        "--backup-base-dir",
        default=os.getenv("BACKUP_BASE_DIR", "/home/jhkim5/backup_sp"),
    )
    parser.add_argument(
        "--max-backup-age-days",
        type=int,
        default=int(os.getenv("MAX_BACKUP_AGE_DAYS", "8")),
    )
    parser.add_argument("--fail-on-blocked", action="store_true")
    args = parser.parse_args(argv)

    checked_at = datetime.utcnow()
    evidence = []
    gate_ids = []
    command_failed = False

    if not args.skip_check:
        result = _run_command(["./scripts/check"])
        evidence.append(
            script_result_to_gate_evidence(
                "compose_config",
                "scripts/check",
                result.returncode,
                checked_at,
                _combined_output(result),
            )
        )
        gate_ids.append("G2")
        command_failed = command_failed or result.returncode != 0

    if not args.skip_web:
        result = _http_get(args.web_url)
        evidence.append(
            script_result_to_gate_evidence(
                "web_health",
                "GET %s" % args.web_url,
                result.returncode,
                checked_at,
                _combined_output(result),
            )
        )
        gate_ids.append("G2")
        command_failed = command_failed or result.returncode != 0

    if args.run_smoke_api:
        result = _run_command(["./scripts/smoke_api"])
        evidence.append(
            script_result_to_gate_evidence(
                "api_health",
                "scripts/smoke_api",
                result.returncode,
                checked_at,
                _combined_output(result),
            )
        )
        gate_ids.append("G2")
        command_failed = command_failed or result.returncode != 0

    if args.run_local_gates:
        evidence.extend(_collect_local_gate_evidence(checked_at))
        gate_ids.extend(["G3", "G4", "G5"])

    if args.run_long_replay:
        evidence.extend(
            _collect_long_replay_evidence(
                args.long_replay_snapshot_path,
                args.long_replay_required_min_days,
                checked_at,
            )
        )
        gate_ids.append("G6")

    if not args.no_backup:
        backup_status = summarize_backup_restore_status(
            Path(args.backup_base_dir),
            max_backup_age_days=args.max_backup_age_days,
            checked_at=checked_at,
        )
        evidence.append(backup_status_to_gate_evidence(backup_status, checked_at))
        gate_ids.append("G8")

    bundle = build_verification_evidence_bundle(
        evidence,
        gate_ids=tuple(dict.fromkeys(gate_ids)),
        generated_at=checked_at,
    )
    output_path = write_verification_evidence_bundle(bundle, Path(args.output))
    if args.write_goldilocks:
        from silver_platter.migrations import connect_goldilocks_from_env
        from silver_platter.repository import GoldilocksRepository

        requirement_to_gate = {
            requirement.requirement_id: requirement.gate_id
            for requirement in DEFAULT_GATE_REQUIREMENTS
        }
        repository = GoldilocksRepository(connect_goldilocks_from_env())
        for assessment in bundle.assessments:
            repository.insert_gate_assessment(assessment, assessed_at=checked_at)
        for item in bundle.evidence:
            gate_id = requirement_to_gate.get(item.requirement_id)
            if gate_id is not None:
                repository.insert_gate_evidence(gate_id, item)

    print("verification evidence bundle written: %s" % output_path)
    for assessment in bundle.assessments:
        print(
            "gate=%s status=%s passed=%s/%s"
            % (
                assessment.gate_id,
                assessment.status,
                assessment.passed_count,
                assessment.total_count,
            )
        )

    if command_failed:
        return 1
    if args.fail_on_blocked and any(
        assessment.status != "pass" for assessment in bundle.assessments
    ):
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
PY
