#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."
. scripts/load_local_env

blocked=0

ready() {
  printf 'ready: %s\n' "$1"
}

block() {
  blocked=1
  printf 'blocked: %s - %s\n' "$1" "$2"
}

skip() {
  printf 'skipped: %s - %s\n' "$1" "$2"
}

user_agent="${SEC_EDGAR_USER_AGENT:-}"
user_agent_lc="$(printf '%s' "${user_agent}" | tr '[:upper:]' '[:lower:]')"
if [ -n "${user_agent}" ] \
  && printf '%s' "${user_agent}" | grep -Eqi '[[:alnum:]._%+-]+@[[:alnum:].-]+\.[[:alpha:]]{2,}' \
  && ! printf '%s' "${user_agent_lc}" | grep -Eqi '@([^[:space:]]+\.)?example\.(com|net|org)([^[:alnum:].-]|$)'; then
  ready "SEC EDGAR User-Agent"
else
  block "SEC EDGAR User-Agent" "set SEC_EDGAR_USER_AGENT to a contact User-Agent with a real email address"
fi

if [ -n "${OPENDART_API_KEY:-}" ]; then
  ready "OpenDART API key"
else
  block "OpenDART API key" "set OPENDART_API_KEY"
fi

if [ -n "${ECOS_API_KEY:-}" ]; then
  ready "ECOS API key"
else
  block "ECOS API key" "set ECOS_API_KEY"
fi

if [ -n "${ALERT_WEBHOOK_URL:-}" ]; then
  ready "alert webhook URL"
else
  skip "alert webhook URL" "ignored by current verification scope"
fi

if [ -n "${GOLDILOCKS_ODBC_CONNECT_STRING:-}" ] \
  || [ -n "${GOLDILOCKS_ODBC_DSN:-}" ] \
  || [ -n "${GOLDILOCKS_ODBC_DRIVER:-}" ]; then
  ready "Goldilocks ODBC history prefetch storage"
else
  block "Goldilocks ODBC history prefetch storage" "set GOLDILOCKS_ODBC_CONNECT_STRING, GOLDILOCKS_ODBC_DSN, or GOLDILOCKS_ODBC_DRIVER"
fi

if [ "${KRX_PRICE_SMOKE_ENABLED:-0}" = "1" ]; then
  ready "KRX price smoke opt-in"
else
  block "KRX price smoke opt-in" "set KRX_PRICE_SMOKE_ENABLED=1 and optionally KRX_PRICE_SMOKE_DATE"
fi

snapshot_path="${LONG_REPLAY_SNAPSHOT_PATH:-${REPLAY_SNAPSHOT_PATH:-}}"
if [ -n "${snapshot_path}" ] && [ -e "${snapshot_path}" ]; then
  ready "long replay snapshot"
else
  block "long replay snapshot" "set LONG_REPLAY_SNAPSHOT_PATH to an existing snapshot file or directory"
fi

g7_evidence_path="${G7_APPROVAL_EVIDENCE_PATH:-var/verification/g7-approval-evidence.json}"
if [ -e "${g7_evidence_path}" ]; then
  ready "G7 approval evidence"
else
  block "G7 approval evidence" "run ./scripts/collect_g7_approval_evidence before manual approval"
fi

if [ "${G7_LIVE_SMOKE_APPROVED:-0}" = "1" ]; then
  ready "G7 live/paper smoke approval"
else
  block "G7 live/paper smoke approval" "set G7_LIVE_SMOKE_APPROVED=1 only after account/risk scope is approved"
fi

if [ "${blocked}" -eq 0 ]; then
  echo "external smoke readiness passed"
else
  echo "external smoke readiness blocked"
fi

exit "${blocked}"
